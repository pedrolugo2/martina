rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read for the progress bar — only Cloud Functions (Admin SDK) can write
    match /donations/total {
      allow read: if true;
      allow write: if false;
    }

    // Payment records are private — Admin SDK only
    match /donations/payments/{paymentId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
