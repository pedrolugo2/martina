# Firebase Web Config (get from Firebase Console → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=martinaflp
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Mercado Pago Public Key (for frontend SDK if needed)
VITE_MP_PUBLIC_KEY=

# Cloud Functions base URL (e.g. https://southamerica-east1-your-project.cloudfunctions.net)
# For local emulator: http://127.0.0.1:5001/YOUR_PROJECT_ID/southamerica-east1
VITE_FUNCTIONS_BASE_URL=
